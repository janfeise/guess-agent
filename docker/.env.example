# 服务名
APP_NAME=guess-agent
# 容器监听的地址和端口
APP_HOST=0.0.0.0
APP_PORT=8000
# 是否启用调试模式
DEBUG=false

# Agent 主模型配置
AGENT_MODEL_API_KEY=agent_key
AGENT_MODEL_BASE_URL=https://api.siliconflow.cn/v1
AGENT_MODEL_NAME=deepseek-ai/DeepSeek-V3.2
AGENT_MODEL_TEMPERATURE=0.3
# 小助手模型配置
HELPER_MODEL_API_KEY=helper_key
HELPER_MODEL_BASE_URL=https://api.siliconflow.cn/v1
HELPER_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
HELPER_MODEL_TEMPERATURE=0.5
# 输入文本的最大字符数
MAX_INPUT_CHARS=1200
# 模型响应的最大时间（秒）
MODEL_TIMEOUT_SECONDS=180
# 最大重试次数
MAX_RETRIES=2

# MongoDB 配置
MONGO_URI=mongodb://root:rootpassword@mongo:27017/guess_agent?authSource=admin
MONGO_DB_NAME=guess_agent

# 加密密钥（用于加密敏感数据）
ENCRYPTION_SECRET=guess-agent-demo-secret
# CORS 配置
CORS_ORIGINS=*